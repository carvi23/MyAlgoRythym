{
  "manifest_version": 3,
  "name": "MyAlgoRythym Companion",
  "version": "1.0",
  "description": "MyAlgoRythym 자동 데이터 수집 확장",
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [{
    "matches": ["*://*.youtube.com/*", "*://*.twitch.tv/*", "*://*.instagram.com/*", "*://*.tiktok.com/*"],
    "js": ["content.js"]
  }],
  "permissions": ["storage", "tabs"],
  "action": {
    "default_popup": "popup.html"
  }
}